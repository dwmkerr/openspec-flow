{
  "name": "@dwmkerr/openspec-flow",
  "version": "0.1.0",
  "description": "Drive OpenSpec spec-driven development from GitHub issues. Open the issue, get a spec PR. Merge it, get an implementation PR.",
  "license": "MIT",
  "private": false,
  "type": "commonjs",
  "main": "./dist/index.js",
  "bin": {
    "openspec-flow": "./bin/openspec-flow"
  },
  "files": [
    "dist",
    "public",
    "templates",
    ".github/actions",
    ".github/workflows/openspec-flow.yml"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "build:watch": "tsc -w",
    "dev": "tsx watch src/server.ts",
    "cli": "tsx src/cli.ts",
    "dev:tunnel": "smee -u $(cat .smee-url 2>/dev/null || echo 'https://smee.io/REPLACE-ME') --path /api/github/webhooks --port 3000",
    "start": "node dist/index.js",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "test": "jest --no-coverage --testPathIgnorePatterns=integration",
    "test:watch": "jest --watch --no-coverage --testPathIgnorePatterns=integration",
    "test:integration": "jest --no-coverage --forceExit --testPathPatterns=integration",
    "test:all": "jest --no-coverage",
    "test:cov": "jest --coverage --testPathIgnorePatterns=integration",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.145",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@octokit/webhooks-types": "^7.6.1",
    "chalk": "^4.1.2",
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jose": "^5.10.0",
    "probot": "^13.4.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@octokit/webhooks-examples": "^7.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.0",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.0.0",
    "nock": "^14.0.0",
    "playwright": "^1.60.0",
    "smee-client": "^4.3.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.4",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=22"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dwmkerr/openspec-flow.git"
  },
  "bugs": {
    "url": "https://github.com/dwmkerr/openspec-flow/issues"
  },
  "homepage": "https://github.com/dwmkerr/openspec-flow#readme",
  "keywords": [
    "openspec",
    "spec-driven",
    "github-bot",
    "claude",
    "agent",
    "probot"
  ],
  "overrides": {
    "esbuild": "^0.28.1",
    "hono": "^4.12.25",
    "js-yaml": "^4.1.0",
    "@babel/core": "^7.29.1"
  }
}
