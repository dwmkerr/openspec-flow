#!/usr/bin/env node
// Entry point for the `openspec-flow` CLI. Resolves to dist/cli.js
// after `npm run build`. For development use `npm run cli` which
// runs the TS source under tsx.

require("../dist/cli.js")
  .runCli(process.argv.slice(2))
  .then((code) => process.exit(code))
  .catch((err) => {
    process.stderr.write("error: " + (err && err.message ? err.message : err) + "\n");
    process.exit(1);
  });
